# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI ChatGPT API
OPENAI_API_KEY=your_openai_api_key_here

# Fußballdaten: openfootball (gemeinfrei, KEIN API-Key nötig).
#   Struktur/Spielplan: github.com/openfootball/worldcup.json
#   Historie:           github.com/openfootball/internationals

# The Odds API (optional — aktiviert "Value vs. Markt"-Feature)
# Free-Tier: 500 Credits/Monat, https://the-odds-api.com
ODDS_API_KEY=

# BALLDONTLIE FIFA WC API (optional — WM-Quoten + Verletzungsinfos)
# Free-Tier verfügbar, https://fifa.balldontlie.io
BALLDONTLIE_API_KEY=

# GitHub Repository-Name (für Pages-Base-Path, z. B. "wm-tipp-agent")
VITE_REPO_NAME=wm-tipp-agent
